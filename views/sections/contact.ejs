<%#
  Contact Section
  - Contact form with glass effect
  - Contact info cards
  - Social links
%>

<section id="contact" class="relative py-20 md:py-32 bg-jjk-darker/50">
  <div class="glow-orb w-96 h-96 bg-jjk-accent-cyan/5 right-[-10%] bottom-[10%]"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    
    <%# Section Header %>
    <div data-aos="fade-up" class="text-center mb-16">
      <span class="text-jjk-purple-light font-mono text-sm mb-2 block">// Contact</span>
      <h2 class="section-heading">
        <span class="text-gradient">Hubungi</span> Saya
      </h2>
      <p class="section-subheading">Hubungi untuk konsultasi akademik atau kerjasama</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
      
      <%# Left - Contact Info %>
      <div data-aos="fade-right" class="lg:col-span-2 space-y-6">
        
        <div class="glass-card p-6">
          <h3 class="text-lg font-bold text-white font-display mb-6">Informasi Kontak</h3>
          <div class="space-y-5">
            <%# Location %>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl glass-card flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h4 class="text-white text-sm font-medium">Lokasi</h4>
                <p class="text-gray-400 text-sm mt-0.5"><%= data.personal.location %></p>
              </div>
            </div>
            
            <%# Email %>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl glass-card flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                </svg>
              </div>
              <div>
                <h4 class="text-white text-sm font-medium">Email</h4>
                <p class="text-gray-400 text-sm mt-0.5"><%= data.personal.email %></p>
              </div>
            </div>
            
            <%# Phone %>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl glass-card flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                </svg>
              </div>
              <div>
                <h4 class="text-white text-sm font-medium">Telepon</h4>
                <p class="text-gray-400 text-sm mt-0.5"><%= data.personal.phone %></p>
              </div>
            </div>
            
            <%# University %>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl glass-card flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0-.96 15.953A60.44 60.44 0 0 1 12 20.674 60.44 60.44 0 0 1 20.7 26.1 60.438 60.438 0 0 0 20.667 10.14m-16.407 0a60.438 60.438 0 0 0 16.407 0M12 3a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z"/>
                </svg>
              </div>
              <div>
                <h4 class="text-white text-sm font-medium">Universitas</h4>
                <p class="text-gray-400 text-sm mt-0.5"><%= data.personal.university %> · <%= data.personal.faculty %></p>
              </div>
            </div>
          </div>
        </div>

        <%# Social Links Card %>
        <div class="glass-card p-6">
          <h3 class="text-lg font-bold text-white font-display mb-4">Ikuti Saya</h3>
          <div class="flex flex-wrap gap-3">
            <a href="<%= data.social.linkedin %>" target="_blank" class="flex-1 min-w-[100px] glass-card p-3 text-center hover:border-jjk-purple/40 hover:text-jjk-purple-light transition-all duration-300 text-gray-400">
              <svg class="w-5 h-5 mx-auto mb-1" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              <span class="text-xs">LinkedIn</span>
            </a>
            <a href="<%= data.social.github %>" target="_blank" class="flex-1 min-w-[100px] glass-card p-3 text-center hover:border-jjk-purple/40 hover:text-jjk-purple-light transition-all duration-300 text-gray-400">
              <svg class="w-5 h-5 mx-auto mb-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              <span class="text-xs">GitHub</span>
            </a>
            <a href="<%= data.social.instagram %>" target="_blank" class="flex-1 min-w-[100px] glass-card p-3 text-center hover:border-jjk-purple/40 hover:text-jjk-purple-light transition-all duration-300 text-gray-400">
              <svg class="w-5 h-5 mx-auto mb-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              <span class="text-xs">Instagram</span>
            </a>
          </div>
        </div>
      </div>

      <%# Right - Contact Form %>
      <div data-aos="fade-left" class="lg:col-span-3">
        <div class="glass-card p-8">
          <h3 class="text-xl font-bold text-white font-display mb-2">Kirim Pesan</h3>
          <p class="text-gray-400 text-sm mb-8">Ada pertanyaan atau ingin berdiskusi? Jangan ragu untuk menghubungi saya.</p>
          
          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm text-gray-300 mb-2">Nama Lengkap <span class="text-jjk-purple-light">*</span></label>
                <input type="text" id="name" name="name" required 
                       class="form-input" placeholder="Nama Anda">
              </div>
              <div>
                <label for="email" class="block text-sm text-gray-300 mb-2">Email <span class="text-jjk-purple-light">*</span></label>
                <input type="email" id="email" name="email" required 
                       class="form-input" placeholder="email@anda.com">
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm text-gray-300 mb-2">Subjek</label>
              <input type="text" id="subject" name="subject" 
                     class="form-input" placeholder="Subjek pesan">
            </div>
            <div>
              <label for="message" class="block text-sm text-gray-300 mb-2">Pesan <span class="text-jjk-purple-light">*</span></label>
              <textarea id="message" name="message" rows="5" required 
                        class="form-input resize-none" placeholder="Tulis pesan Anda di sini..."></textarea>
            </div>
            
            <div class="flex items-center gap-4">
              <button type="submit" class="btn-glow">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
                </svg>
                Kirim Pesan
              </button>
              <div id="form-status" class="text-sm hidden"></div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
