<%#
  Hero Section
  - Full-screen with animated background
  - Typing effect for titles
  - CTA buttons
%>

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  
  <%# Decorative glow orbs %>
  <div class="glow-orb w-96 h-96 bg-jjk-purple/20 top-[-10%] left-[-10%]"></div>
  <div class="glow-orb w-80 h-80 bg-jjk-blue-glow/15 bottom-[-5%] right-[-5%]"></div>
  <div class="glow-orb w-60 h-60 bg-jjk-accent-cyan/10 top-[40%] right-[20%]"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10 w-full">
    <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-16">
      
      <%# Right - Profile Image or Animation (masukin ke atas di mobile) %>
      <div data-aos="fade-left" data-aos-delay="300" class="flex-shrink-0 order-first lg:order-last">
        <div class="relative">
          <%# Glow ring %>
          <div class="absolute inset-0 rounded-full bg-jjk-purple/20 blur-3xl animate-glow-pulse"></div>
          
          <%# Avatar frame - lebih kecil di mobile %>
          <div class="relative w-40 h-40 sm:w-56 sm:h-56 md:w-64 md:h-64 lg:w-80 lg:h-80">
            <div class="absolute inset-0 rounded-full border-2 border-jjk-purple/30 animate-glow-pulse"></div>
            <div class="absolute inset-2 rounded-full border border-jjk-accent-cyan/20"></div>
            
            <div class="absolute inset-4 rounded-full bg-jjk-purple/10 flex items-center justify-center overflow-hidden backdrop-blur-sm border border-white/5">
              <div class="text-center p-4 sm:p-6">
                <div class="w-20 h-20 sm:w-24 sm:h-24 md:w-32 md:h-32 mx-auto rounded-full bg-gradient-to-br from-jjk-purple to-jjk-blue-glow flex items-center justify-center mb-2 sm:mb-3 shadow-neon-strong">
                  <span class="text-3xl sm:text-4xl md:text-5xl font-bold text-white font-display"><%= data.personal.nickname[0] %></span>
                </div>
                <p class="text-xs text-gray-500 hidden sm:block">Foto Profile</p>
              </div>
            </div>

            <%# Floating elements - hide on mobile %>
            <div class="absolute -top-2 -right-2 w-10 h-10 sm:w-12 sm:h-12 rounded-xl glass-card flex items-center justify-center animate-float border-jjk-purple/20">
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="absolute -bottom-2 -left-2 w-8 h-8 sm:w-10 sm:h-10 rounded-xl glass-card flex items-center justify-center animate-float border-jjk-accent-cyan/20 hidden sm:flex" style="animation-delay: 2s;">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <%# Left Content %>
      <div class="flex-1 text-center lg:text-left">
        
        <%# Greeting with fade animation %>
        <div data-aos="fade-up" data-aos-delay="100">
          <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full glass-card text-xs sm:text-sm text-jjk-purple-light mb-4 sm:mb-6 border-jjk-purple/20">
            <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-jjk-purple animate-pulse"></span>
            Fullstack Developer & Dosen
          </div>
        </div>
        
        <%# Name with neon effect %>
        <h1 data-aos="fade-up" data-aos-delay="200" class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold font-display leading-tight mb-3 sm:mb-4">
          <span class="text-gray-300">Halo, saya</span><br>
          <span class="text-gradient text-neon"><%= data.personal.nickname %></span>
        </h1>
        
        <%# Dynamic titles with typing effect %>
        <div data-aos="fade-up" data-aos-delay="300" class="h-8 sm:h-10 md:h-12 mb-4 sm:mb-6">
          <span id="typing-text" class="text-base sm:text-lg md:text-xl lg:text-2xl text-jjk-accent-cyan font-mono" data-titles='<%= JSON.stringify(data.personal.titles) %>'></span>
          <span class="inline-block w-0.5 h-5 sm:h-6 md:h-7 bg-jjk-accent-cyan animate-pulse ml-1"></span>
        </div>
        
        <%# Description %>
        <p data-aos="fade-up" data-aos-delay="400" class="text-gray-400 text-sm sm:text-base md:text-lg leading-relaxed max-w-xl mx-auto lg:mx-0 mb-6 sm:mb-8">
          <%= data.personal.headline %>
        </p>
        
        <%# CTA Buttons %>
        <div data-aos="fade-up" data-aos-delay="500" class="flex flex-wrap gap-3 justify-center lg:justify-start">
          <a href="#projects" class="btn-glow text-sm sm:text-base px-4 sm:px-6 py-2.5 sm:py-3">
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Lihat Karya
          </a>
          <a href="#contact" class="btn-outline-glow text-sm sm:text-base px-4 sm:px-6 py-2.5 sm:py-3">
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Hubungi
          </a>
          <a href="#about" class="btn-outline-glow border-jjk-accent-cyan/40 text-jjk-accent-cyan hover:bg-jjk-accent-cyan/10 hover:border-jjk-accent-cyan text-sm sm:text-base px-4 sm:px-6 py-2.5 sm:py-3 hidden sm:inline-flex">
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
            Selengkapnya
          </a>
        </div>

        <%# Stats Bar %>
        <div data-aos="fade-up" data-aos-delay="600" class="flex flex-wrap gap-4 sm:gap-6 md:gap-10 mt-8 sm:mt-12 justify-center lg:justify-start">
          <% data.about.stats.forEach(stat => { %>
            <div class="text-center lg:text-left">
              <div class="text-xl sm:text-2xl md:text-3xl font-bold text-white font-display"><%= stat.value %></div>
              <div class="text-xs sm:text-sm text-gray-500"><%= stat.label %></div>
            </div>
          <% }) %>
        </div>
      </div>

    </div>
  </div>

  <%# Scroll indicator %>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-jjk-purple/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
