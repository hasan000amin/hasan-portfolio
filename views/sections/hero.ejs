<%#
  Hero Section
  - Full-screen with animated background
  - Typing effect for titles
  - CTA buttons
%>

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  
  <%# Decorative glow orbs %>
  <div class="glow-orb w-96 h-96 bg-jjk-purple/20 top-[-10%] left-[-10%]"></div>
  <div class="glow-orb w-80 h-80 bg-jjk-blue-glow/15 bottom-[-5%] right-[-5%]"></div>
  <div class="glow-orb w-60 h-60 bg-jjk-accent-cyan/10 top-[40%] right-[20%]"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10 w-full">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">
      
      <%# Left Content %>
      <div class="flex-1 text-center md:text-left">
        
        <%# Greeting with fade animation %>
        <div data-aos="fade-up" data-aos-delay="100">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass-card text-xs md:text-sm text-jjk-purple-light mb-6 border-jjk-purple/20">
            <span class="w-2 h-2 rounded-full bg-jjk-purple animate-pulse"></span>
            Fullstack Developer & Dosen
          </div>
        </div>
        
        <%# Name with neon effect %>
        <h1 data-aos="fade-up" data-aos-delay="200" class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-display leading-tight mb-4">
          <span class="text-gray-300">Halo, saya</span><br>
          <span class="text-gradient text-neon"><%= data.personal.nickname %></span>
        </h1>
        
        <%# Dynamic titles with typing effect %>
        <div data-aos="fade-up" data-aos-delay="300" class="h-10 md:h-12 mb-6">
          <span id="typing-text" class="text-xl md:text-2xl text-jjk-accent-cyan font-mono" data-titles='<%= JSON.stringify(data.personal.titles) %>'></span>
          <span class="inline-block w-0.5 h-6 md:h-7 bg-jjk-accent-cyan animate-pulse ml-1"></span>
        </div>
        
        <%# Description %>
        <p data-aos="fade-up" data-aos-delay="400" class="text-gray-400 text-base md:text-lg leading-relaxed max-w-xl mx-auto md:mx-0 mb-8">
          <%= data.personal.headline %>
        </p>
        
        <%# CTA Buttons %>
        <div data-aos="fade-up" data-aos-delay="500" class="flex flex-wrap gap-4 justify-center md:justify-start">
          <a href="#projects" class="btn-glow">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Lihat Karya
          </a>
          <a href="#contact" class="btn-outline-glow">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Hubungi Saya
          </a>
          <a href="#about" class="btn-outline-glow border-jjk-accent-cyan/40 text-jjk-accent-cyan hover:bg-jjk-accent-cyan/10 hover:border-jjk-accent-cyan">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
            Selengkapnya
          </a>
        </div>

        <%# Stats Bar %>
        <div data-aos="fade-up" data-aos-delay="600" class="flex flex-wrap gap-6 md:gap-10 mt-12 justify-center md:justify-start">
          <% data.about.stats.forEach(stat => { %>
            <div class="text-center md:text-left">
              <div class="text-2xl md:text-3xl font-bold text-white font-display"><%= stat.value %></div>
              <div class="text-xs md:text-sm text-gray-500"><%= stat.label %></div>
            </div>
          <% }) %>
        </div>
      </div>

      <%# Right - Profile Image or Animation %>
      <div data-aos="fade-left" data-aos-delay="300" class="flex-shrink-0">
        <div class="relative">
          <%# Glow ring %>
          <div class="absolute inset-0 rounded-full bg-jjk-purple/20 blur-3xl animate-glow-pulse"></div>
          
          <%# Hexagon/avatar frame %>
          <div class="relative w-64 h-64 md:w-80 md:h-80">
            <!-- Animated border -->
            <div class="absolute inset-0 rounded-full border-2 border-jjk-purple/30 animate-glow-pulse"></div>
            <div class="absolute inset-2 rounded-full border border-jjk-accent-cyan/20"></div>
            
            <%# Profile image or placeholder %>
            <div class="absolute inset-4 rounded-full bg-jjk-purple/10 flex items-center justify-center overflow-hidden backdrop-blur-sm border border-white/5">
              <%# TODO: Ganti dengan foto profil asli %>
              <div class="text-center p-6">
                <div class="w-24 h-24 md:w-32 md:h-32 mx-auto rounded-full bg-gradient-to-br from-jjk-purple to-jjk-blue-glow flex items-center justify-center mb-3 shadow-neon-strong">
                  <span class="text-4xl md:text-5xl font-bold text-white font-display"><%= data.personal.nickname[0] %></span>
                </div>
                <p class="text-xs text-gray-500">Foto Profile</p>
              </div>
            </div>

            <%# Floating elements decoration %>
            <div class="absolute -top-2 -right-2 w-12 h-12 rounded-xl glass-card flex items-center justify-center animate-float border-jjk-purple/20">
              <svg class="w-6 h-6 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="absolute -bottom-2 -left-2 w-10 h-10 rounded-xl glass-card flex items-center justify-center animate-float border-jjk-accent-cyan/20" style="animation-delay: 2s;">
              <svg class="w-5 h-5 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Scroll indicator %>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-jjk-purple/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
