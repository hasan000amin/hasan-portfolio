<%#
  Projects Section
  - Card grid with category filters
  - Hover effects with gradient top border
  - Tech tags
%>

<section id="projects" class="relative py-20 md:py-32 bg-jjk-darker/50">
  <div class="glow-orb w-96 h-96 bg-jjk-blue-glow/5 left-[-10%] top-[30%]"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    
    <%# Section Header %>
    <div data-aos="fade-up" class="text-center mb-10 sm:mb-12 md:mb-16">
      <span class="text-jjk-purple-light font-mono text-sm mb-2 block">// Projects</span>
      <h2 class="section-heading">
        <span class="text-gradient">Karya</span> Proyek
      </h2>
      <p class="section-subheading">Aplikasi dan sistem yang telah saya bangun selama 10+ tahun</p>
    </div>

    <%# Filter buttons - horizontal scroll on mobile %>
    <div data-aos="fade-up" class="flex flex-wrap justify-center gap-2 mb-10 overflow-x-auto pb-2 scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0">
      <button class="filter-btn active px-3 sm:px-4 py-2 rounded-xl text-xs sm:text-sm font-medium transition-all duration-300 bg-jjk-purple text-white whitespace-nowrap" data-filter="all">
        Semua
      </button>
      <button class="filter-btn px-3 sm:px-4 py-2 rounded-xl text-xs sm:text-sm font-medium transition-all duration-300 glass-card hover:border-jjk-purple/30 text-gray-400 hover:text-jjk-purple-light whitespace-nowrap" data-filter="Web App">
        Web App
      </button>
      <button class="filter-btn px-3 sm:px-4 py-2 rounded-xl text-xs sm:text-sm font-medium transition-all duration-300 glass-card hover:border-jjk-purple/30 text-gray-400 hover:text-jjk-purple-light whitespace-nowrap" data-filter="IoT">
        IoT
      </button>
      <button class="filter-btn px-3 sm:px-4 py-2 rounded-xl text-xs sm:text-sm font-medium transition-all duration-300 glass-card hover:border-jjk-purple/30 text-gray-400 hover:text-jjk-purple-light whitespace-nowrap" data-filter="Industrial Automation">
        Industrial
      </button>
      <button class="filter-btn px-3 sm:px-4 py-2 rounded-xl text-xs sm:text-sm font-medium transition-all duration-300 glass-card hover:border-jjk-purple/30 text-gray-400 hover:text-jjk-purple-light whitespace-nowrap" data-filter="Machine Learning">
        ML
      </button>
    </div>

    <%# Projects Grid - responsive columns %>
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-6" id="projects-grid">
      <% data.projects.forEach((project, index) => { %>
        <div class="project-card group <%= project.category === 'Web App' ? 'show' : 'show' %>" 
             data-category="<%= project.category %>"
             data-aos="fade-up" data-aos-delay="<%= (index % 6) * 50 %>">
          
          <%# Project icon based on category %>
          <div class="w-12 h-12 rounded-xl bg-jjk-purple/10 flex items-center justify-center mb-4 group-hover:bg-jjk-purple/20 transition-colors">
            <% if (project.category === 'IoT') { %>
              <svg class="w-6 h-6 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/></svg>
            <% } else if (project.category === 'Machine Learning') { %>
              <svg class="w-6 h-6 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
            <% } else if (project.category === 'Industrial Automation') { %>
              <svg class="w-6 h-6 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
            <% } else { %>
              <svg class="w-6 h-6 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
            <% } %>
          </div>
          
          <%# Year and category badge %>
          <div class="flex items-center gap-2 mb-3">
            <span class="px-2 py-0.5 rounded-md text-xs font-mono text-jjk-purple-light bg-jjk-purple/10"><%= project.year %></span>
            <span class="px-2 py-0.5 rounded-md text-xs bg-jjk-glass-heavy text-gray-400"><%= project.category %></span>
          </div>
          
          <h3 class="text-lg font-bold text-white font-display mb-2 group-hover:text-jjk-purple-light transition-colors">
            <%= project.title %>
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-4"><%= project.description %></p>
          
          <%# Tech tags %>
          <div class="flex flex-wrap gap-1 mb-3 sm:mb-4">
            <% project.tech.forEach(t => { %>
              <span class="px-1.5 sm:px-2 py-0.5 rounded-md text-[10px] sm:text-xs bg-jjk-glass-light text-gray-400"><%= t %></span>
            <% }) %>
          </div>
          
          <%# Links %>
          <div class="flex items-center gap-3 mt-auto pt-3 border-t border-white/5">
            <a href="<%= project.link %>" target="_blank" class="text-xs text-jjk-purple-light hover:text-jjk-purple transition-colors flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
              Demo
            </a>
            <a href="<%= project.github %>" target="_blank" class="text-xs text-gray-500 hover:text-jjk-accent-cyan transition-colors flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Source
            </a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
