<%#
  Experience Section
  - Timeline layout
  - Work history with animations
%>

<section id="experience" class="relative py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    
    <%# Section Header %>
    <div data-aos="fade-up" class="text-center mb-10 sm:mb-12 md:mb-16">
      <span class="text-jjk-purple-light font-mono text-sm mb-2 block"><%= __('experience.code') %></span>
      <h2 class="section-heading">
        <span class="text-gradient"><%= __('experience.heading') %></span> <%= __('experience.heading_exp') %>
      </h2>
      <p class="section-subheading"><%= __('experience.subtitle') %></p>
    </div>

    <%# Timeline %>
    <div class="relative">
      <%# Timeline line (adjust for mobile) %>
      <div class="timeline-line"></div>

      <div class="space-y-6 sm:space-y-10">
        <% data.experiences.forEach((exp, index) => { %>
          <div class="relative" data-aos="<%= index % 2 === 0 ? 'fade-right' : 'fade-left' %>" data-aos-delay="<%= index * 100 %>">
            <div class="flex flex-col md:flex-row items-start gap-4 md:gap-10">
              
              <%# Timeline dot - desktop %>
              <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-10 h-10 rounded-full glass-card border-2 border-jjk-purple items-center justify-center z-10">
                <% if (exp.type === 'work') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                  </svg>
                <% } else { %>
                  <svg class="w-4 h-4 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0-.96 15.953A60.44 60.44 0 0 1 12 20.674 60.44 60.44 0 0 1 20.7 26.1 60.438 60.438 0 0 0 20.667 10.14m-16.407 0a60.438 60.438 0 0 0 16.407 0M12 3a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z"/>
                  </svg>
                <% } %>
              </div>

              <%# Mobile dot - keep on left edge %>
              <div class="flex md:hidden absolute left-0 top-1 w-8 h-8 rounded-full glass-card border-2 border-jjk-purple items-center justify-center z-10 -translate-x-1/2">
                <div class="w-2 h-2 rounded-full bg-jjk-purple"></div>
              </div>

              <%# Content Card - full width on mobile, offset for timeline line %>
              <div class="glass-card p-4 sm:p-5 md:p-8 ml-8 md:ml-0 w-full max-w-full md:w-[calc(50%-2rem)] break-words overflow-hidden <%= index % 2 === 0 ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8' %>">
                <div class="flex flex-wrap items-center gap-1.5 sm:gap-2 mb-2">
                  <span class="px-2 sm:px-2.5 py-0.5 rounded-md text-xs font-mono text-jjk-accent-cyan bg-jjk-accent-cyan/10">
                    <%= _d(exp.period).replace('Sekarang', __('experience.badge_present')) %>
                  </span>
                  <% if (exp.type === 'work') { %>
                    <span class="px-1.5 sm:px-2 py-0.5 rounded-md text-xs bg-jjk-purple/10 text-jjk-purple-light"><%= __('experience.badge_work') %></span>
                  <% } else { %>
                    <span class="px-1.5 sm:px-2 py-0.5 rounded-md text-xs bg-jjk-accent-cyan/10 text-jjk-accent-cyan">Pendidikan</span>
                  <% } %>
                </div>
                <h3 class="text-base sm:text-lg md:text-xl font-bold text-white font-display mb-1 break-words"><%= _d(exp.title) %></h3>
                <p class="text-jjk-purple-light text-xs sm:text-sm mb-2 sm:mb-3 break-words"><%= exp.company %></p>
                <p class="text-gray-400 text-xs sm:text-sm leading-relaxed break-words"><%= _d(exp.description) %></p>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <%# Teaching Activity %>
    <div data-aos="fade-up" class="mt-20">
      <div class="text-center mb-10">
        <span class="text-jjk-purple-light font-mono text-sm mb-2 block"><%= __('experience.code') %></span>
        <h3 class="text-2xl md:text-3xl font-bold font-display">
          <%= __('experience.teaching_title') %>
        </h3>
        <p class="text-gray-500 mt-2"><%= __('experience.teaching_subtitle') %></p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <% data.teaching.forEach((course, index) => { %>
          <div class="glass-card p-5 text-center hover:border-jjk-purple/30 transition-all duration-300" 
               data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="w-12 h-12 rounded-xl bg-jjk-purple/10 flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M4.26 10.147a60.438 60.438 0 0-.96 15.953A60.44 60.44 0 0 1 12 20.674 60.44 60.44 0 0 1 20.7 26.1 60.438 60.438 0 0 0 20.667 10.14m-16.407 0a60.438 60.438 0 0 0 16.407 0M12 3a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z"/>
              </svg>
            </div>
            <h4 class="text-white font-semibold text-sm"><%= course.course %></h4>
            <p class="text-jjk-purple-light text-xs mt-1"><%= course.sks %> SKS</p>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>
