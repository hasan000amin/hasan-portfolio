<%#
  Certificates Section
  - Certificate cards
  - Including publications and training
%>

<section id="certificates" class="relative py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    
    <%# Section Header %>
    <div data-aos="fade-up" class="text-center mb-10 sm:mb-12 md:mb-16">
      <span class="text-jjk-purple-light font-mono text-sm mb-2 block"><%= __('certificates.code') %></span>
      <h2 class="section-heading">
        <span class="text-gradient"><%= __('certificates.heading') %></span> <%= __('certificates.heading_cert') %>
      </h2>
      <p class="section-subheading"><%= __('certificates.subtitle') %></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-12 sm:mb-16">
      <% data.certificates.forEach((cert, index) => { %>
        <div class="glass-card p-4 sm:p-6 hover:border-jjk-purple/30 transition-all duration-300 group"
             data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
          
          <%# Certificate icon %>
          <div class="w-10 h-10 sm:w-14 sm:h-14 rounded-2xl bg-gradient-to-br from-jjk-accent-cyan/20 to-jjk-purple/20 flex items-center justify-center mb-3 sm:mb-4 group-hover:shadow-neon-cyan transition-all duration-300">
            <svg class="w-5 h-5 sm:w-7 sm:h-7 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
            </svg>
          </div>
          
          <h3 class="text-base sm:text-lg font-bold text-white font-display mb-1"><%= cert.title %></h3>
          <p class="text-jjk-purple-light text-xs sm:text-sm mb-1 sm:mb-2"><%= cert.issuer %> · <%= cert.year %></p>
          <p class="text-gray-400 text-xs sm:text-sm leading-relaxed"><%= _d(cert.description) %></p>
          
          <a href="<%= cert.link %>" target="_blank" class="inline-flex items-center gap-1.5 text-xs text-jjk-accent-cyan hover:text-jjk-accent-cyan/80 transition-colors mt-3 sm:mt-4">
            <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
            </svg>
            <%= __('certificates.view') %>
          </a>
        </div>
      <% }) %>
    </div>

    <%# Google Scholar Badge %>
    <div data-aos="fade-up" class="glass-card p-6 sm:p-8 text-center max-w-2xl mx-auto">
      <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-2xl bg-gradient-to-br from-jjk-purple/20 to-jjk-accent-cyan/20 flex items-center justify-center mx-auto mb-3 sm:mb-4">
        <svg class="w-6 h-6 sm:w-8 sm:h-8 text-jjk-purple-light" viewBox="0 0 24 24" fill="currentColor">
          <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/>
        </svg>
      </div>
      <h3 class="text-lg sm:text-xl font-bold text-white font-display mb-2"><%= __('certificates.scholar_title') %></h3>
      <p class="text-gray-400 text-xs sm:text-sm mb-1"><%= data.personal.citations %> <%= __('certificates.scholar_citations') %> · h-index <%= data.personal.hIndex %></p>
      <p class="text-gray-500 text-xs mb-3 sm:mb-4"><%= __('certificates.scholar_desc') %></p>
      <a href="<%= data.personal.googleScholar %>" target="_blank" class="btn-outline-glow text-xs sm:text-sm inline-flex">
        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/>
        </svg>
        <%= __('certificates.scholar_button') %>
      </a>
    </div>
  </div>
</section>
