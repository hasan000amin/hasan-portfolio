<%#
  Skills Section
  - Skill bars with percentage
  - Animated on scroll
  - Categorized skills
%>

<section id="skills" class="relative py-20 md:py-32 bg-jjk-darker/50">
  <div class="glow-orb w-80 h-80 bg-jjk-purple/10 left-[-5%] bottom-[10%]"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    
    <%# Section Header %>
    <div data-aos="fade-up" class="text-center mb-16">
      <span class="text-jjk-purple-light font-mono text-sm mb-2 block">// Skills</span>
      <h2 class="section-heading">
        <span class="text-gradient">Keahlian</span> Teknis
      </h2>
      <p class="section-subheading">Bidang keahlian yang saya kuasai selama 10+ tahun berkarya</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% data.skills.forEach((skill, index) => { %>
        <div data-aos="fade-up" data-aos-delay="<%= index * 50 %>" 
             class="glass-card p-5 group hover:border-jjk-purple/30 transition-all duration-300">
          
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg bg-jjk-purple/10 flex items-center justify-center group-hover:bg-jjk-purple/20 transition-colors">
                <%# Dynamic icons based on skill name %>
                <% if (skill.icon === 'code-2') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>
                <% } else if (skill.icon === 'server') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z"/></svg>
                <% } else if (skill.icon === 'globe') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>
                <% } else if (skill.icon === 'cpu') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/></svg>
                <% } else if (skill.icon === 'radio') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 7.5l16.5-4.125M12 6v2.25m8.25 3.75l-16.5 4.125M12 18v-2.25m0 0l-8.25-2.0625M12 18l8.25-2.0625M12 2.25v1.5m0 15v1.5"/></svg>
                <% } else if (skill.icon === 'gauge') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
                <% } else if (skill.icon === 'microchip') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3.75H6.912a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859M12 3v8.25m0 0l-3-3m3 3l3-3"/></svg>
                <% } else if (skill.icon === 'monitor') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
                <% } else if (skill.icon === 'brain') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
                <% } else if (skill.icon === 'shield') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                <% } else if (skill.icon === 'terminal') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/></svg>
                <% } else if (skill.icon === 'network') { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a3 3 0 100-6 3 3 0 000 6zm0 0V9m0 0l-4.5 4.5M12 9l4.5 4.5"/></svg>
                <% } else { %>
                  <svg class="w-4 h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6"/></svg>
                <% } %>
              </div>
              <span class="text-white font-medium text-sm"><%= skill.name %></span>
            </div>
            <span class="text-jjk-purple-light text-xs font-mono"><%= skill.level %>%</span>
          </div>
          
          <%# Progress bar %>
          <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-jjk-purple to-jjk-accent-cyan rounded-full transition-all duration-1000 ease-out"
                 style="width: 0%;"
                 data-width="<%= skill.level %>%">
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
