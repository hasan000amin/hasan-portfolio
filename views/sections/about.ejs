<%#
  About Me Section
  - Profile overview with stats
  - Bio paragraphs
  - Key highlights
%>

<section id="about" class="relative py-20 md:py-32">
  <div class="glow-orb w-96 h-96 bg-jjk-blue-glow/10 right-[-10%] top-[20%]"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    
    <%# Section Header %>
    <div data-aos="fade-up" class="text-center mb-10 sm:mb-12 md:mb-16">
      <span class="text-jjk-purple-light font-mono text-sm mb-2 block">// About</span>
      <h2 class="section-heading">
        <span class="text-gradient">Tentang</span> Saya
      </h2>
      <p class="section-subheading">Kenali lebih dekat perjalanan profesional saya</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-16">
      
      <%# Left - Profile Info Card %>
      <div data-aos="fade-right" class="lg:col-span-2">
        <div class="glass-card p-5 sm:p-6 lg:p-8 lg:sticky lg:top-24">
          
          <%# Avatar %>
          <div class="flex items-center gap-4 lg:block">
            <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-gradient-to-br from-jjk-purple to-jjk-blue-glow flex items-center justify-center mb-0 lg:mb-6 shadow-neon flex-shrink-0">
              <span class="text-2xl sm:text-3xl font-bold text-white font-display"><%= data.personal.nickname[0] %></span>
            </div>
            <div class="lg:mb-6">
              <h3 class="text-lg sm:text-xl font-bold text-white font-display"><%= data.personal.name %></h3>
              <p class="text-jjk-purple-light text-xs sm:text-sm"><%= data.personal.titles[0] %></p>
            </div>
          </div>
          
          <%# Info list %>
          <div class="space-y-3 sm:space-y-4 text-xs sm:text-sm mt-5 lg:mt-0">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg glass-card flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <span class="text-gray-500 block">Lokasi</span>
                <span class="text-gray-200"><%= data.personal.location %></span>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg glass-card flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <span class="text-gray-500 block">Email</span>
                <span class="text-gray-200"><%= data.personal.email %></span>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg glass-card flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 21v-2a4 4 0 00-4-4H9a4 4 0 00-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
              <div>
                <span class="text-gray-500 block">Universitas</span>
                <span class="text-gray-200"><%= data.personal.university %></span>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg glass-card flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                </svg>
              </div>
              <div>
                <span class="text-gray-500 block">Google Scholar</span>
                <span class="text-gray-200"><%= data.personal.citations %> sitasi · h-index <%= data.personal.hIndex %></span>
              </div>
            </div>
          </div>

          <%# Resume Button %>
          <a href="#" class="btn-outline-glow w-full justify-center mt-5 sm:mt-8 text-xs sm:text-sm">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Download CV
            <!-- TODO: Tambah file CV PDF -->
          </a>
        </div>
      </div>

      <%# Right - About Content %>
      <div data-aos="fade-left" class="lg:col-span-3 space-y-5 sm:space-y-6">
        <% data.about.description.forEach((paragraph, index) => { %>
          <p class="text-gray-400 leading-relaxed text-sm sm:text-base md:text-lg" 
             data-aos="fade-up" data-aos-delay="<%= 100 + index * 100 %>">
            <%= paragraph %>
          </p>
        <% }) %>

        <%# Key highlights grid %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mt-6 sm:mt-10">
          <div class="glass-card p-4 sm:p-5 text-center" data-aos="fade-up" data-aos-delay="300">
            <div class="text-2xl sm:text-3xl mb-2">🏢</div>
            <h4 class="text-white font-semibold text-xs sm:text-sm">PT. Sinergi Sarana Teknologi</h4>
            <p class="text-gray-500 text-xs mt-1">Remote Developer · 2019–Sekarang</p>
          </div>
          <div class="glass-card p-4 sm:p-5 text-center" data-aos="fade-up" data-aos-delay="400">
            <div class="text-2xl sm:text-3xl mb-2">🎓</div>
            <h4 class="text-white font-semibold text-xs sm:text-sm">Universitas Pamulang</h4>
            <p class="text-gray-500 text-xs mt-1">Dosen S1 Sistem Komputer · 2024–Sekarang</p>
          </div>
          <div class="glass-card p-4 sm:p-5 text-center" data-aos="fade-up" data-aos-delay="500">
            <div class="text-2xl sm:text-3xl mb-2">🏫</div>
            <h4 class="text-white font-semibold text-xs sm:text-sm">STT Duta Bangsa</h4>
            <p class="text-gray-500 text-xs mt-1">Software Developer · 2014–2024</p>
          </div>
          <div class="glass-card p-4 sm:p-5 text-center" data-aos="fade-up" data-aos-delay="600">
            <div class="text-2xl sm:text-3xl mb-2">📚</div>
            <h4 class="text-white font-semibold text-xs sm:text-sm">Google Scholar</h4>
            <p class="text-gray-500 text-xs mt-1"><%= data.personal.citations %> Sitasi · h-index <%= data.personal.hIndex %></p>
          </div>
        </div>

        <%# Community Service %>
        <div class="glass-card p-4 sm:p-6 mt-6 sm:mt-8" data-aos="fade-up">
          <h4 class="text-white font-semibold mb-3 sm:mb-4 flex items-center gap-2 text-sm sm:text-base">
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            Pengabdian Masyarakat (PKM)
          </h4>
          <div class="space-y-2 sm:space-y-3">
            <% data.communityServices.forEach(svc => { %>
              <div class="flex items-start gap-2 sm:gap-3 p-2.5 sm:p-3 rounded-xl bg-jjk-glass-light">
                <span class="px-1.5 sm:px-2 py-0.5 rounded-md text-xs font-mono text-jjk-accent-cyan bg-jjk-accent-cyan/10 flex-shrink-0 mt-0.5">
                  <%= svc.year %>
                </span>
                <div>
                  <p class="text-xs sm:text-sm text-gray-200 font-medium"><%= svc.title %></p>
                  <p class="text-xs text-gray-500 mt-0.5"><%= svc.description %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
        
        <%# Publications %>
        <div class="glass-card p-4 sm:p-6 mt-4 sm:mt-6" data-aos="fade-up">
          <h4 class="text-white font-semibold mb-3 sm:mb-4 flex items-center gap-2 text-sm sm:text-base">
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-jjk-accent-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
            </svg>
            Publikasi Terbaru
          </h4>
          <div class="space-y-2 sm:space-y-3">
            <% data.publications.forEach(pub => { %>
              <div class="p-2.5 sm:p-3 rounded-xl bg-jjk-glass-light">
                <p class="text-xs sm:text-sm text-gray-200 font-medium"><%= pub.title %></p>
                <p class="text-xs text-gray-500 mt-1"><%= pub.journal %> · <%= pub.year %></p>
                <p class="text-xs text-gray-600"><%= pub.authors %></p>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
