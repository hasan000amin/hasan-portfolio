<%#
  Tech Stack Section
  - Grid of technology icons grouped by category
  - Devicon CDN for icons
%>

<section id="techstack" class="relative py-20 md:py-32 bg-jjk-darker/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    
    <%# Section Header %>
    <div data-aos="fade-up" class="text-center mb-10 sm:mb-12 md:mb-16">
      <span class="text-jjk-purple-light font-mono text-sm mb-2 block"><%= __('techstack.code') %></span>
      <h2 class="section-heading">
        <span class="text-gradient"><%= __('techstack.heading') %></span> <%= __('techstack.heading_tech') %>
      </h2>
      <p class="section-subheading"><%= __('techstack.subtitle') %></p>
    </div>

    <%# Group technologies by category %>
    <% 
      const categories = {};
      data.techStack.forEach(t => {
        if (!categories[t.category]) categories[t.category] = [];
        categories[t.category].push(t);
      });
    %>

    <div class="space-y-8 sm:space-y-12">
      <% Object.keys(categories).forEach((category, catIdx) => { %>
        <div data-aos="fade-up" data-aos-delay="<%= catIdx * 50 %>">
          <h3 class="text-base sm:text-lg font-semibold text-white font-display mb-4 sm:mb-6 flex items-center gap-2 sm:gap-3">
            <span class="w-4 sm:w-8 h-0.5 bg-jjk-purple/50 rounded-full"></span>
            <%= category %>
            <span class="w-4 sm:w-8 h-0.5 bg-jjk-purple/50 rounded-full"></span>
          </h3>
          
          <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-2 sm:gap-4">
            <% categories[category].forEach((tech, index) => { %>
              <div class="glass-card p-2 sm:p-4 text-center group hover:border-jjk-purple/30 hover:shadow-neon transition-all duration-300 cursor-default"
                   data-aos="fade-up" data-aos-delay="<%= 50 + index * 30 %>">
                
                <%# Tech icon %>
                <div class="w-8 h-8 sm:w-12 sm:h-12 mx-auto mb-1 sm:mb-3 flex items-center justify-center">
                  <% if (tech.icon) { %>
                    <img src="<%= tech.icon %>" alt="<%= tech.name %>" 
                         class="w-6 h-6 sm:w-10 sm:h-10 object-contain group-hover:scale-110 transition-transform duration-300"
                         onerror="this.onerror=null; this.parentElement.innerHTML='<div class=\\'w-6 h-6 sm:w-10 sm:h-10 rounded-xl bg-jjk-purple/20 flex items-center justify-center\\'><span class=\\'text-xs font-bold text-jjk-purple-light\\'>' + this.alt.charAt(0) + '</span></div>'">
                  <% } else { %>
                    <div class="w-6 h-6 sm:w-10 sm:h-10 rounded-xl bg-jjk-purple/20 flex items-center justify-center group-hover:bg-jjk-purple/30 transition-colors">
                      <span class="text-[8px] sm:text-xs font-bold text-jjk-purple-light"><%= tech.name.charAt(0) %></span>
                    </div>
                  <% } %>
                </div>
                
                <span class="text-[10px] sm:text-xs text-gray-400 group-hover:text-gray-200 transition-colors font-medium"><%= tech.name %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
