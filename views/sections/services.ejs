<%#
  Services Section
  - Service cards with features list
  - Hover effects
%>

<section id="services" class="relative py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    
    <%# Section Header %>
    <div data-aos="fade-up" class="text-center mb-10 sm:mb-12 md:mb-16">
      <span class="text-jjk-purple-light font-mono text-sm mb-2 block">// Services</span>
      <h2 class="section-heading">
        <span class="text-gradient">Layanan</span> Saya
      </h2>
      <p class="section-subheading">Solusi teknologi yang saya tawarkan untuk kebutuhan Anda</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-6">
      <% data.services.forEach((service, index) => { %>
        <div class="glass-card p-5 sm:p-6 lg:p-8 hover:border-jjk-purple/30 transition-all duration-500 group"
             data-aos="fade-up" data-aos-delay="<%= index * 80 %>">
          
          <%# Icon %>
          <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-2xl bg-gradient-to-br from-jjk-purple/20 to-jjk-blue-glow/20 flex items-center justify-center mb-4 sm:mb-5 group-hover:shadow-neon transition-all duration-500 group-hover:from-jjk-purple/30 group-hover:to-jjk-blue-glow/30">
            <% if (service.icon === 'globe') { %>
              <svg class="w-6 h-6 sm:w-7 sm:h-7 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>
            <% } else if (service.icon === 'cpu') { %>
              <svg class="w-6 h-6 sm:w-7 sm:h-7 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/></svg>
            <% } else if (service.icon === 'gauge') { %>
              <svg class="w-6 h-6 sm:w-7 sm:h-7 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
            <% } else if (service.icon === 'shield') { %>
              <svg class="w-6 h-6 sm:w-7 sm:h-7 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            <% } else if (service.icon === 'brain') { %>
              <svg class="w-6 h-6 sm:w-7 sm:h-7 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
            <% } else { %>
              <svg class="w-6 h-6 sm:w-7 sm:h-7 text-jjk-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/></svg>
            <% } %>
          </div>
          
          <h3 class="text-lg sm:text-xl font-bold text-white font-display mb-2 sm:mb-3"><%= service.title %></h3>
          <p class="text-gray-400 text-xs sm:text-sm leading-relaxed mb-4 sm:mb-6"><%= service.description %></p>
          
          <%# Features list %>
          <ul class="space-y-2">
            <% service.features.forEach(f => { %>
              <li class="flex items-center gap-2 text-xs sm:text-sm text-gray-400">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-jjk-purple-light flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                <%= f %>
              </li>
            <% }) %>
          </ul>
        </div>
      <% }) %>
    </div>
  </div>
</section>
