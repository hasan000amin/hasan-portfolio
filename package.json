{
  "name": "portfolio-hasan-amin",
  "version": "1.0.0",
  "description": "Portfolio website - Hasan Amin - Fullstack Developer & Dosen",
  "main": "app.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:server\"",
    "dev:server": "nodemon app.js",
    "dev:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --watch",
    "build": "tailwindcss -i ./src/input.css -o ./public/css/style.css --minify",
    "start": "node app.js",
    "lint": "echo 'Lint not configured yet'"
  },
  "keywords": ["portfolio", "hasan-amin", "fullstack", "developer"],
  "author": "Hasan Amin",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4"
  }
}
